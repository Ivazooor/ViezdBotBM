# Токен бота из @BotFather (после /revoke вставьте НОВЫЙ токен)
TELEGRAM_BOT_TOKEN=replace_with_new_bot_token

# ID целевого чата/группы, куда бот пересылает готовые отчёты.
# Как узнать: добавьте бота в группу и откройте
# https://api.telegram.org/bot<ТОКЕН>/getUpdates — там будет chat.id (для групп он отрицательный).
TELEGRAM_CHAT_ID=replace_with_chat_id

# Telegram ID сотрудников, которым разрешено отправлять отчёты (через запятую, без пробелов).
# Как узнать ID: сотрудник пишет нашему боту — бот ответит его ID; либо бот @userinfobot.
# Пример: ALLOWED_USER_IDS=12345678,98765432
ALLOWED_USER_IDS=

PORT=3000
