# Токен бота из @BotFather (после /revoke вставьте НОВЫЙ токен)
TELEGRAM_BOT_TOKEN=replace_with_new_bot_token

# ID целевого чата/группы, куда бот пересылает готовые отчёты.
# Как узнать: добавьте бота в группу и откройте
# https://api.telegram.org/bot<ТОКЕН>/getUpdates — там будет chat.id (для групп он отрицательный).
TELEGRAM_CHAT_ID=replace_with_chat_id

# Telegram ID сотрудников, которым разрешено отправлять отчёты (через запятую, без пробелов).
# Как узнать ID: сотрудник пишет нашему боту — бот ответит его ID; либо бот @userinfobot.
# Пример: ALLOWED_USER_IDS=12345678,98765432
ALLOWED_USER_IDS=

PORT=3000

# ===== Фирменный PDF-отчёт (только заключительный выезд) =====
# Реквизиты в подвале PDF, который уходит заказчику. Имеют разумные значения по умолчанию,
# задавайте только если нужно переопределить.
PDF_SITE=бизнес-макет.рф
PDF_MANAGER_NAME=Вербицкий Матвей Михайлович
PDF_MANAGER_PHONE=+7 985 433-75-90
# Максимум фото, вставляемых в PDF (защита от тяжёлого файла).
PDF_MAX_PHOTOS=20

# Telegram ID тех, кто может оценивать качество выезда кнопками в рабочем чате.
# По умолчанию список зашит в коде (этим людям также автоматически открыт доступ к боту);
# задавайте здесь, только если нужно переопределить. Через запятую, без пробелов.
QUALITY_REVIEWER_IDS=
